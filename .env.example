# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# GitHub (public 레포는 없어도 되지만 rate limit 방지용)
GITHUB_TOKEN=your_github_personal_access_token

# dev.to
# https://dev.to/settings/extensions → DEV Community API Keys
DEVTO_API_KEY=your_devto_api_key

# Hashnode
# https://hashnode.com/settings/developer → API Keys
HASHNODE_API_KEY=your_hashnode_api_key
# 내 블로그 Publication ID (hashnode.com/settings → 블로그 URL에서 확인)
HASHNODE_PUBLICATION_ID=your_hashnode_publication_id

# 설정
TARGET_REPO_URL=https://github.com/meene11/it-news-pipeline
SEO_SCORE_THRESHOLD=70
